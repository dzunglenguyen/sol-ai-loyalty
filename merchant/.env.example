# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Clerk — lấy từ Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# LLM provider switch: "xai" or "gemini"
LLM_PROVIDER=gemini

# xAI (Grok)
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.20-reasoning

# Google Gemini (OpenAI-compatible)
GEMINI_API_KEY=AIza...
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3-flash-preview

# QR Payment (optional — defaults provided)
# NEXT_PUBLIC_QR_BANK_BIN=970424
# NEXT_PUBLIC_QR_ACCOUNT_NUMBER=0352352525
# NEXT_PUBLIC_QR_MERCHANT_CITY=HO CHI MINH

DEBUG_VISION=1

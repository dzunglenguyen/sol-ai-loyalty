# ── Alibaba Cloud API Gateway ─────────────────────────────────────────────────
ALIBABA_API_GATEWAY_URL=https://<your-api-gateway-id>.cn-hangzhou.alicloudapi.com

# ── PAI-EAS Propensity Scoring ────────────────────────────────────────────────
PAI_EAS_ENDPOINT=https://<your-eas-endpoint>.cn-hangzhou.pai-eas.aliyuncs.com/api/predict/sol-propensity-scorer
PAI_EAS_TOKEN=<your-pai-eas-token>

# ── DashVector ────────────────────────────────────────────────────────────────
DASHVECTOR_ENDPOINT=https://<your-instance>.cn-hangzhou.dashvector.aliyuncs.com
DASHVECTOR_API_KEY=<your-dashvector-api-key>
DASHVECTOR_COLLECTION=user-embeddings

# ── PolarDB for MySQL ─────────────────────────────────────────────────────────
POLARDB_HOST=<your-polardb-host>.mysql.polardb.rds.aliyuncs.com
POLARDB_PORT=3306
POLARDB_USER=<db-user>
POLARDB_PASSWORD=<db-password>
POLARDB_DATABASE=sol_loyalty

# ── Qwen-Plus (Model Studio) ──────────────────────────────────────────────────
QWEN_API_KEY=<your-model-studio-api-key>
QWEN_MODEL=qwen-plus

# ── QR Signing ────────────────────────────────────────────────────────────────
ALIBABA_QR_SECRET=<random-32-char-secret>

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_KEY=<your-anon-or-service-role-key>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
